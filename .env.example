# Server
PORT=3000
CROSS_SEED_HOST=127.0.0.1
CROSS_SEED_PORT=2468

# Required for cross-seed API access
CROSS_SEED_API_KEY=replace_with_cross_seed_api_key

# UI auth
CROSS_SEED_UI_USERNAME=admin
CROSS_SEED_UI_PASSWORD=change_me
CROSS_SEED_UI_SESSION_SECRET=change_me_with_a_long_random_secret

# Optional explicit env file path
CROSS_SEED_UI_ENV_FILE=/root/cross-seed-ui-secrets/.env.local

# Paths
CROSS_SEED_CONFIG_PATH=/root/.cross-seed/config.js
CROSS_SEED_LOGS_DIR=/root/.cross-seed/logs
