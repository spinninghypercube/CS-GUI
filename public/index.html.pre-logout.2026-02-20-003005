<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>cross-seed</title>
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #21262d;
    --border: #30363d;
    --text: #e6edf3;
    --muted: #8b949e;
    --accent: #58a6ff;
    --success: #3fb950;
    --error: #f85149;
    --warning: #d29922;
    --info: #79c0ff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 14px; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

  /* Header */
  header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 20px; display: flex; align-items: center; gap: 16px; height: 52px; flex-shrink: 0; }
  .logo { font-weight: 700; font-size: 16px; color: var(--text); display: flex; align-items: center; gap: 8px; }
  .logo-icon { color: var(--success); font-size: 18px; }
  .status-badge { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--muted); transition: background 0.3s; }
  .dot.up { background: var(--success); box-shadow: 0 0 6px var(--success); }
  .dot.down { background: var(--error); }
  .version-tag { font-size: 11px; color: var(--muted); background: var(--surface2); padding: 2px 8px; border-radius: 12px; border: 1px solid var(--border); margin-left: auto; }

  /* Tabs */
  nav { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 20px; display: flex; gap: 4px; flex-shrink: 0; }
  .tab { padding: 10px 16px; cursor: pointer; color: var(--muted); border-bottom: 2px solid transparent; font-size: 13px; font-weight: 500; transition: color 0.15s, border-color 0.15s; user-select: none; }
  .tab:hover { color: var(--text); }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  /* Content */
  .content { flex: 1; overflow: hidden; display: flex; flex-direction: column; }
  .panel { display: none; flex: 1; overflow: hidden; flex-direction: column; }
  .panel.active { display: flex; }

  /* Toast */
  #toast-container { position: fixed; bottom: 20px; right: 20px; display: flex; flex-direction: column; gap: 8px; z-index: 1000; }
  .toast { padding: 10px 16px; border-radius: 6px; font-size: 13px; background: var(--surface2); border: 1px solid var(--border); color: var(--text); animation: slideIn 0.2s ease; max-width: 340px; }
  .toast.success { border-color: var(--success); color: var(--success); }
  .toast.error { border-color: var(--error); color: var(--error); }
  .toast.info { border-color: var(--accent); color: var(--accent); }
  @keyframes slideIn { from { transform: translateX(20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

  /* ── LOGS PANEL ── */
  .logs-toolbar { display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0; flex-wrap: wrap; width: 100%; }
  .log-type-toggle { display: flex; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
  .log-type-btn { padding: 5px 14px; background: transparent; border: none; color: var(--muted); cursor: pointer; font-size: 12px; font-weight: 500; transition: background 0.15s, color 0.15s; }
  .log-type-btn.active { background: var(--accent); color: #fff; }
  .log-range-select { padding: 5px 10px; background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; color: var(--muted); font-size: 12px; cursor: pointer; outline: none; }
  .log-range-select:focus { border-color: var(--accent); }
  option { background: var(--surface2); }
  .toolbar-sep { width: 1px; height: 20px; background: var(--border); margin: 0 4px; }
  .toolbar-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }
  .auto-scroll-label { display: flex; align-items: center; gap: 6px; cursor: pointer; color: var(--muted); font-size: 12px; user-select: none; }
  .auto-scroll-label input { accent-color: var(--accent); cursor: pointer; }
  .btn-sm { padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border); background: var(--surface2); color: var(--text); cursor: pointer; font-size: 12px; transition: background 0.15s; white-space: nowrap; }
  .btn-sm:hover { background: var(--border); }

  /* Job buttons inline */
  .job-btn { padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border); background: var(--surface2); color: var(--muted); cursor: pointer; font-size: 12px; font-weight: 500; transition: border-color 0.15s, color 0.15s, background 0.15s; white-space: nowrap; display: inline-flex; align-items: center; gap: 5px; }
  .job-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .job-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .job-btn.running { border-color: var(--warning); color: var(--warning); }
  .job-btn.success { border-color: var(--success); color: var(--success); }
  .job-btn.error-state { border-color: var(--error); color: var(--error); }
  .spinner { display: inline-block; width: 10px; height: 10px; border: 2px solid currentColor; border-top-color: transparent; border-radius: 50%; animation: spin 0.6s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  #log-viewer { flex: 1; overflow-y: auto; padding: 10px 16px; font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace; font-size: 12px; line-height: 1.6; background: var(--bg); }
  .log-line { padding: 1px 0; white-space: pre-wrap; word-break: break-all; }
  .log-line .ts { color: #484f58; }
  .log-line .level-verbose { color: var(--muted); }
  .log-line .level-info { color: var(--info); }
  .log-line .level-error { color: var(--error); }
  .log-line .level-warn { color: var(--warning); }
  .log-line .tag { color: #6e40c9; }
  .log-line .msg-verbose { color: #6e7681; }
  .log-line .msg-info { color: var(--text); }
  .log-line .msg-error { color: var(--error); }
  .log-line .msg-warn { color: var(--warning); }
  .log-status { color: var(--muted); font-style: italic; padding: 8px 0; }

  .range-selects { display: flex; gap: 8px; }
  .job-buttons { display: flex; align-items: center; gap: 8px; flex: 1; }
  .job-buttons .job-btn, .job-buttons .btn-sm { flex: 1; justify-content: center; }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .logs-toolbar { flex-wrap: wrap; }
    .log-type-toggle { width: 100%; }
    .log-type-btn { flex: 1; text-align: center; }
    .range-selects { width: 100%; }
    .range-selects .log-range-select { flex: 1; min-width: 0; }
    .job-buttons { width: 100%; flex: none; }
    .toolbar-sep { display: none; }
.toolbar-right { width: 100%; margin-left: 0; }
  }

  /* ── CONFIG PANEL ── */
  .config-toolbar { padding: 10px 16px; background: var(--surface); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .config-toolbar-info { margin-left: auto; font-size: 11px; color: var(--muted); }
  .btn-primary { padding: 7px 16px; border-radius: 6px; border: none; background: var(--accent); color: #fff; cursor: pointer; font-size: 13px; font-weight: 500; transition: opacity 0.15s; }
  .btn-primary:hover:not(:disabled) { opacity: 0.85; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  #config-editor { flex: 1; resize: none; background: var(--bg); color: var(--text); border: none; padding: 16px; font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace; font-size: 12px; line-height: 1.7; outline: none; overflow-y: auto; tab-size: 4; }
</style>
</head>
<body>

<header>
  <div class="logo">
    <span class="logo-icon">⟳</span>
    cross-seed
  </div>
  <div class="status-badge">
    <div class="dot" id="daemon-dot"></div>
    <span id="daemon-label">checking...</span>
  </div>
  <span class="version-tag" id="version-tag">v6.13.6 · ui4</span>
</header>

<nav>
  <div class="tab active" data-panel="logs">Logs</div>
  <div class="tab" data-panel="config">Config</div>
</nav>

<div class="content">

  <!-- LOGS -->
  <div class="panel active" id="panel-logs">
    <div class="logs-toolbar">
      <div class="log-type-toggle">
        <button class="log-type-btn active" data-type="verbose">Verbose</button>
        <button class="log-type-btn" data-type="error">Error</button>
        <button class="log-type-btn" data-type="success">Success</button>
      </div>
      <div class="toolbar-sep"></div>
      <div class="range-selects">
        <select class="log-range-select" id="select-lines">
          <option value="">Past X lines</option>
          <option value="100">Past 100 lines</option>
          <option value="300" selected>Past 300 lines</option>
          <option value="500">Past 500 lines</option>
          <option value="1000">Past 1000 lines</option>
          <option value="5000">Past 5000 lines</option>
          <option value="all">All lines</option>
        </select>
        <select class="log-range-select" id="select-since">
          <option value="">Past X time</option>
          <option value="1h">Past 1h</option>
          <option value="5h">Past 5h</option>
          <option value="1d">Past 1 day</option>
          <option value="1w">Past 1 week</option>
          <option value="1m">Past 1 month</option>
          <option value="all">All time</option>
        </select>
      </div>
      <div class="toolbar-sep"></div>
      <div class="job-buttons">
        <button class="job-btn" id="btn-job-rss" data-job="rss">📡 RSS</button>
        <button class="job-btn" id="btn-job-search" data-job="search">🔍 Search</button>
        <button class="job-btn" id="btn-job-inject" data-job="inject">💉 Inject</button>
        <button class="btn-sm" id="btn-restart" style="border-color:var(--error);color:var(--error)">↺ Restart</button>
      </div>
      <div class="toolbar-sep"></div>
      <div class="toolbar-right">
        <label class="auto-scroll-label">
          <input type="checkbox" id="auto-scroll" checked>
          Auto-scroll
        </label>
        <button class="btn-sm" id="btn-clear-logs">Clear</button>
        <button class="btn-sm" id="btn-pause-logs">Pause</button>
      </div>
    </div>
    <div id="log-viewer">
      <div class="log-status">Connecting to log stream...</div>
    </div>
  </div>

  <!-- CONFIG -->
  <div class="panel" id="panel-config">
    <div class="config-toolbar">
      <button class="btn-sm" id="btn-reload-config">Reload from disk</button>
      <button class="btn-primary" id="btn-save-config">Save Config</button>
      <span class="config-toolbar-info" id="config-info">Auto-backup is created before every save.</span>
    </div>
    <textarea id="config-editor" spellcheck="false"></textarea>
  </div>

</div>

<div id="toast-container"></div>

<script>
// ── State ──────────────────────────────────────────────
let logType = 'verbose';
let logFilter = null; // null = show all, 'success' = filter client-side
let logPaused = false;
let autoScroll = true;
let logEventSource = null;
let lineCount = 0;
let pendingLines = [];
let streamGen = 0; // incremented on every new stream; prevents stale ready events
const MAX_LINES = 1000;
const BATCH_SIZE = 200; // max lines rendered per 100ms tick

// Flush pending lines to DOM every 100ms in controlled batches
setInterval(() => {
  if (pendingLines.length === 0) return;
  // If there's more than we'll ever show, drop the oldest to avoid processing thousands of lines
  if (pendingLines.length > MAX_LINES) pendingLines = pendingLines.slice(-MAX_LINES);
  const batch = pendingLines.splice(0, BATCH_SIZE);
  const viewer = document.getElementById('log-viewer');
  const placeholder = viewer.querySelector('.log-status');
  if (placeholder) placeholder.remove();
  const fragment = document.createDocumentFragment();
  for (const line of batch) fragment.appendChild(colorLine(line));
  viewer.appendChild(fragment);
  while (viewer.children.length > MAX_LINES) viewer.removeChild(viewer.firstChild);
  lineCount = viewer.children.length;
  if (autoScroll) viewer.scrollTop = viewer.scrollHeight;
}, 100);

const SUCCESS_PATTERN = /\binfo:.*\bMATCH(_PARTIAL)?\b.*- injected/;

// ── Tabs ───────────────────────────────────────────────
document.querySelectorAll('.tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('panel-' + tab.dataset.panel).classList.add('active');
    if (tab.dataset.panel === 'config') loadConfig();
  });
});

// ── Toast ──────────────────────────────────────────────
function toast(msg, type = 'info', duration = 4000) {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), duration);
}

// ── Daemon ping ────────────────────────────────────────
async function pingDaemon() {
  const dot = document.getElementById('daemon-dot');
  const label = document.getElementById('daemon-label');
  try {
    const r = await fetch('/api/ping');
    const data = await r.json();
    if (data.status === 'up') {
      dot.className = 'dot up';
      label.textContent = 'Daemon online';
    } else {
      dot.className = 'dot down';
      label.textContent = 'Daemon offline';
    }
  } catch {
    dot.className = 'dot down';
    label.textContent = 'Daemon offline';
  }
}
pingDaemon();
setInterval(pingDaemon, 15000);

// ── Log coloring ───────────────────────────────────────
function colorLine(raw) {
  const m = raw.match(/^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}(?:\.\d+)?)\s+(verbose|info|error|warn):\s+(\[\w+[@\d.:]*\]|\[\w+\])\s*(.*)$/);
  if (!m) {
    const el = document.createElement('div');
    el.className = 'log-line';
    el.style.color = 'var(--muted)';
    el.textContent = raw;
    return el;
  }
  const [, ts, level, tag, msg] = m;
  const el = document.createElement('div');
  el.className = 'log-line';
  el.innerHTML =
    `<span class="ts">${ts}</span> ` +
    `<span class="level-${level}">${level}:</span> ` +
    `<span class="tag">${escHtml(tag)}</span> ` +
    `<span class="msg-${level}">${escHtml(msg)}</span>`;
  return el;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── Log stream ─────────────────────────────────────────
function appendLine(raw) {
  if (logPaused) return;
  if (logFilter === 'success' && !SUCCESS_PATTERN.test(raw)) return;
  pendingLines.push(raw);
}

function startLogStream(type) {
  if (logEventSource) logEventSource.close();
  const viewer = document.getElementById('log-viewer');
  viewer.innerHTML = '<div class="log-status">Retrieving...</div>';
  lineCount = 0;
  pendingLines = [];
  const myGen = ++streamGen; // capture generation for this stream

  const lines = document.getElementById('select-lines').value;
  const since = document.getElementById('select-since').value;
  const params = new URLSearchParams({ type });
  if (logFilter === 'success') params.set('filter', 'success');
  if (since) params.set('since', since);
  else if (lines) params.set('lines', lines);
  else params.set('lines', '300');

  logEventSource = new EventSource(`/api/logs/stream?${params}`);
  logEventSource.onmessage = (e) => {
    if (streamGen !== myGen) return; // stale stream, ignore
    try { appendLine(JSON.parse(e.data)); } catch (_) { appendLine(e.data); }
  };
  logEventSource.addEventListener('ready', (e) => {
    if (streamGen !== myGen) return; // stale stream, ignore
    const { count } = JSON.parse(e.data);
    if (count === 0 && pendingLines.length === 0 && lineCount === 0) {
      viewer.innerHTML = '<div class="log-status">No results for this filter.</div>';
    } else if (count > 0) {
      // Server found lines — update placeholder so it's visible while batch renderer catches up
      const status = viewer.querySelector('.log-status');
      if (status) status.textContent = `Loading ${count} lines…`;
    }
  });
  logEventSource.onerror = () => {
    if (streamGen !== myGen) return;
    const s = document.createElement('div');
    s.className = 'log-status';
    s.textContent = 'Stream disconnected. Reconnecting...';
    document.getElementById('log-viewer').appendChild(s);
  };
}

startLogStream(logType);

document.getElementById('select-lines').addEventListener('change', (e) => {
  if (e.target.value) document.getElementById('select-since').value = '';
  startLogStream(logType);
});

document.getElementById('select-since').addEventListener('change', (e) => {
  if (e.target.value) document.getElementById('select-lines').value = '';
  startLogStream(logType);
});

document.querySelectorAll('.log-type-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.log-type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const type = btn.dataset.type;
    if (type === 'success') {
      logFilter = 'success';
      // stream verbose but filter client-side
      if (logType !== 'verbose') { logType = 'verbose'; startLogStream('verbose'); }
      else { startLogStream('verbose'); } // restart to re-apply filter from beginning
    } else {
      logFilter = null;
      logType = type;
      startLogStream(type);
    }
  });
});

document.getElementById('auto-scroll').addEventListener('change', (e) => {
  autoScroll = e.target.checked;
});

document.getElementById('log-viewer').addEventListener('scroll', (e) => {
  const el = e.target;
  const atBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 40;
  if (!atBottom && autoScroll) {
    autoScroll = false;
    document.getElementById('auto-scroll').checked = false;
  }
});

document.getElementById('btn-clear-logs').addEventListener('click', () => {
  document.getElementById('log-viewer').innerHTML = '';
  pendingLines = [];
  lineCount = 0;
});

document.getElementById('btn-pause-logs').addEventListener('click', (e) => {
  logPaused = !logPaused;
  e.target.textContent = logPaused ? 'Resume' : 'Pause';
  e.target.style.color = logPaused ? 'var(--warning)' : '';
});

// ── Job buttons ────────────────────────────────────────
document.querySelector('.job-buttons').querySelectorAll('.job-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const jobName = btn.dataset.job;
    const origHTML = btn.innerHTML;

    btn.disabled = true;
    btn.className = 'job-btn running';
    btn.innerHTML = `<span class="spinner"></span> ${jobName}`;

    try {
      const r = await fetch(`/api/job/${jobName}`, { method: 'POST' });
      const data = await r.json();
      if (r.ok || r.status === 202) {
        btn.className = 'job-btn success';
        btn.innerHTML = `✓ ${jobName}`;
        toast(`${jobName}: ${data.response || 'triggered'}`, 'success');
      } else {
        btn.className = 'job-btn error-state';
        btn.innerHTML = `✗ ${jobName}`;
        toast(`${jobName} failed: ${JSON.stringify(data.response || data.error)}`, 'error', 6000);
      }
    } catch (err) {
      btn.className = 'job-btn error-state';
      btn.innerHTML = `✗ ${jobName}`;
      toast(`Error: ${err.message}`, 'error');
    }

    setTimeout(() => {
      btn.disabled = false;
      btn.className = 'job-btn';
      btn.innerHTML = origHTML;
    }, 4000);
  });
});

// ── Restart ────────────────────────────────────────────
(function() {
  const btn = document.getElementById('btn-restart');
  let confirming = false;
  let timer = null;

  btn.addEventListener('click', async () => {
    if (!confirming) {
      confirming = true;
      btn.textContent = 'Sure?';
      btn.style.background = 'var(--error)';
      btn.style.color = '#fff';
      timer = setTimeout(() => {
        confirming = false;
        btn.textContent = '↺ Restart';
        btn.style.background = '';
        btn.style.color = 'var(--error)';
      }, 3000);
      return;
    }
    clearTimeout(timer);
    confirming = false;
    btn.disabled = true;
    btn.textContent = 'Restarting...';
    btn.style.background = '';
    btn.style.color = 'var(--warning)';
    try {
      await fetch('/api/restart', { method: 'POST' });
      btn.textContent = '✓ Restarted';
      btn.style.color = 'var(--success)';
      toast('cross-seed daemon restarted', 'success');
    } catch {
      btn.textContent = '✗ Failed';
      btn.style.color = 'var(--error)';
      toast('Restart failed', 'error');
    }
    setTimeout(() => {
      btn.disabled = false;
      btn.textContent = '↺ Restart';
      btn.style.color = 'var(--error)';
    }, 3000);
  });
})();

// ── Config ─────────────────────────────────────────────
let configLoaded = false;

async function loadConfig() {
  if (configLoaded) return;
  const info = document.getElementById('config-info');
  info.textContent = 'Loading...';
  try {
    const r = await fetch('/api/config');
    const data = await r.json();
    if (data.error) throw new Error(data.error);
    document.getElementById('config-editor').value = data.content;
    info.textContent = 'Auto-backup is created before every save.';
    configLoaded = true;
  } catch (e) {
    info.textContent = 'Failed to load: ' + e.message;
    toast('Failed to load config: ' + e.message, 'error');
  }
}

document.getElementById('btn-reload-config').addEventListener('click', async () => {
  configLoaded = false;
  document.getElementById('config-info').textContent = 'Reloading...';
  await loadConfig();
  toast('Config reloaded from disk', 'info');
});

document.getElementById('btn-save-config').addEventListener('click', async () => {
  const btn = document.getElementById('btn-save-config');
  const info = document.getElementById('config-info');
  const content = document.getElementById('config-editor').value;
  btn.disabled = true;
  btn.textContent = 'Saving...';
  info.textContent = '';
  try {
    const r = await fetch('/api/config', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content }),
    });
    const data = await r.json();
    if (data.error) throw new Error(data.error);
    info.textContent = `Saved. Backup: ${data.backup}`;
    toast('Config saved successfully', 'success');
  } catch (e) {
    info.textContent = 'Save failed: ' + e.message;
    toast('Save failed: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Save Config';
  }
});

document.getElementById('config-editor').addEventListener('keydown', (e) => {
  if (e.key === 'Tab') {
    e.preventDefault();
    const el = e.target;
    const start = el.selectionStart;
    const end = el.selectionEnd;
    el.value = el.value.substring(0, start) + '    ' + el.value.substring(end);
    el.selectionStart = el.selectionEnd = start + 4;
  }
});
</script>
</body>
</html>
